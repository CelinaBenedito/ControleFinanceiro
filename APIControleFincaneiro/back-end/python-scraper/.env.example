# ── API ────────────────────────────────────────────────────────────────────────
API_PORT=8000
API_HOST=127.0.0.1

# ── Pasta onde os .ofx serão salvos (relativo ao python-scraper/) ──────────────
# Padrão aponta para uploads/ofx do back-end Java
# OFX_OUTPUT_DIR=../uploads/ofx

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_TYPE=chromium
HEADLESS=false
BROWSER_TIMEOUT=300000

# ── Timeouts ──────────────────────────────────────────────────────────────────
LOGIN_TIMEOUT=300
DOWNLOAD_TIMEOUT=60

